# WiFi Visual Packet Monitor - Environment Config Template
# Copy this to .env and fill in your own values
# cp .env.example .env

# App
PORT=3001

# WiFi Router Admin (optional — enables real device block/unblock via router API)
ROUTER_IP=192.168.0.1
ROUTER_SSID=YOUR_WIFI_NAME
ROUTER_ADMIN_USER=admin
ROUTER_ADMIN_PASSWORD=your_router_password_here

# Scan interval in milliseconds (default: 30000 = 30s)
SCAN_INTERVAL_MS=30000
